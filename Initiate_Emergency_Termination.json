{
  "id": "0******************************c",
  "name": "Initiate_Emergency_Termination",
  "description": "Initiate_Emergency_Termination",
  "definition": {
    "start": "Interactive Form",
    "steps": {
      "Compare Numbers": {
        "actionId": "sp:compare-numbers",
        "choiceList": [
          {
            "comparator": "NumericEquals",
            "nextStep": "Send Email",
            "variableA.$": "$.hTTPRequest.statusCode",
            "variableB": 200
          }
        ],
        "defaultStep": "Send Email 1",
        "displayName": "Check if API call was successful",
        "type": "choice"
      },
      "Compare Numbers 1": {
        "actionId": "sp:compare-numbers",
        "choiceList": [
          {
            "comparator": "NumericEquals",
            "nextStep": "Send Email",
            "variableA.$": "$.hTTPRequest1.statusCode",
            "variableB": 200
          }
        ],
        "defaultStep": "Send Email 1",
        "displayName": "Check if API call was successful",
        "type": "choice"
      },
      "Compare Strings 1": {
        "actionId": "sp:compare-strings",
        "choiceList": [
          {
            "comparator": "StringEquals",
            "nextStep": "HTTP Request",
            "variableA.$": "$.getIdentity1.attributes.cloudLifecycleState",
            "variableB": "active"
          }
        ],
        "defaultStep": "Compare Strings 2",
        "displayName": "Check if user is in active lifecycle state",
        "type": "choice"
      },
      "Compare Strings 2": {
        "actionId": "sp:compare-strings",
        "choiceList": [
          {
            "comparator": "StringEquals",
            "nextStep": "HTTP Request 1",
            "variableA.$": "$.getIdentity1.attributes.cloudLifecycleState",
            "variableB": "prehire"
          }
        ],
        "defaultStep": "End Step - Success",
        "displayName": "Check if user is in prehire lifecycle state",
        "type": "choice"
      },
      "Compare Strings 3": {
        "actionId": "sp:compare-strings",
        "choiceList": [
          {
            "comparator": "StringMatches",
            "nextStep": "Interactive Message",
            "variableA.$": "$.getIdentity1.attributes.cloudLifecycleState",
            "variableB": "^(terminated|rescinded)$"
          }
        ],
        "defaultStep": "Interactive Form 1",
        "displayName": "Check if user is already in any of the inactive lifecycle state",
        "type": "choice"
      },
      "Compare Strings 4": {
        "actionId": "sp:compare-strings",
        "choiceList": [
          {
            "comparator": "StringDoesNotEquals",
            "nextStep": "Interactive Message 1",
            "variableA.$": "$.getIdentity1.attributes.cloudAuthoritativeSource",
            "variableB": "f*******************************0"
          }
        ],
        "defaultStep": "Compare Strings 3",
        "displayName": "Check if user belongs to Non Person Auth Source",
        "type": "choice"
      },
      "End Step - Success": {
        "actionId": "sp:operator-success",
        "displayName": "",
        "type": "success"
      },
      "Get Identity": {
        "actionId": "sp:get-identity",
        "attributes": {
          "id.$": "$.trigger.launchedBy.id"
        },
        "displayName": "Get Requester's Identity",
        "nextStep": "Get Identity 1",
        "type": "action",
        "versionNumber": 2
      },
      "Get Identity 1": {
        "actionId": "sp:get-identity",
        "attributes": {
          "id.$": "$.interactiveForm.formData.accountId"
        },
        "displayName": "Get Selected User's Identity",
        "nextStep": "Compare Strings 4",
        "type": "action",
        "versionNumber": 2
      },
      "HTTP Request": {
        "actionId": "sp:http",
        "attributes": {
          "authenticationType": "OAuth",
          "jsonRequestBody": {
            "lifecycleStateId": "c**************************1"
          },
          "method": "post",
          "oAuthClientId": "b*************************9",
          "oAuthCredentialLocation": "oAuthInHeader",
          "oAuthTokenUrl": "https://tenant.api.identitynow.com/oauth/token",
          "requestContentType": "json",
          "url": "https://tenant.api.identitynow.com/v3/identities/{{$.interactiveForm.formData.accountId}}/set-lifecycle-state"
        },
        "displayName": "Change user's lifecycle state to terminated",
        "nextStep": "Compare Numbers",
        "type": "action",
        "versionNumber": 2
      },
      "HTTP Request 1": {
        "actionId": "sp:http",
        "attributes": {
          "authenticationType": "OAuth",
          "jsonRequestBody": {
            "lifecycleStateId": "8******************************d"
          },
          "method": "post",
          "oAuthClientId": "b****************************9",
          "oAuthCredentialLocation": "oAuthInHeader",
          "oAuthTokenUrl": "https://tenant.api.identitynow.com/oauth/token",
          "requestContentType": "json",
          "url": "https://tenant.api.identitynow.com/v3/identities/{{$.interactiveForm.formData.accountId}}/set-lifecycle-state"
        },
        "displayName": "Change user's lifecycle state to rescinded",
        "nextStep": "Compare Numbers 1",
        "type": "action",
        "versionNumber": 2
      },
      "Interactive Form": {
        "actionId": "sp:interactive-form",
        "attributes": {
          "formDefinitionId": "1*******************************f",
          "interactiveProcessId.$": "$.trigger.interactiveProcessId",
          "ownerId.$": "$.trigger.launchedBy.id",
          "title": "Initiate Emergency Termination"
        },
        "displayName": "Display User Selection Form",
        "nextStep": "Get Identity",
        "type": "action",
        "versionNumber": 1
      },
      "Interactive Form 1": {
        "actionId": "sp:interactive-form",
        "attributes": {
          "formDefinitionId": "c*************************3",
          "inputForForm_accountId.$": "$.getIdentity1.attributes.accountId",
          "inputForForm_displayName.$": "$.getIdentity1.attributes.displayName",
          "inputForForm_email.$": "$.getIdentity1.attributes.email",
          "inputForForm_employeeType.$": "$.getIdentity1.attributes.userType",
          "inputForForm_primaryDomain.$": "$.getIdentity1.attributes.primaryDomain",
          "interactiveProcessId.$": "$.trigger.interactiveProcessId",
          "ownerId.$": "$.trigger.launchedBy.id",
          "title": "User Details Form"
        },
        "displayName": "Display user details Form",
        "nextStep": "Compare Strings 1",
        "type": "action",
        "versionNumber": 1
      },
      "Interactive Message": {
        "actionId": "sp:interactive-message",
        "attributes": {
          "category": "ERROR",
          "interactiveProcessId.$": "$.trigger.interactiveProcessId",
          "message": "<p>Hello,<br><br>Immediate termination cannot be processed as this user is already terminated.</p>\n<p>Thank You,<br>Support</p>",
          "ownerId.$": "$.trigger.launchedBy.id",
          "title": "Emergency Termination Failed"
        },
        "displayName": "Display message for already inactive user",
        "nextStep": "End Step - Success",
        "type": "action",
        "versionNumber": 1
      },
      "Interactive Message 1": {
        "actionId": "sp:interactive-message",
        "attributes": {
          "category": "ERROR",
          "interactiveProcessId.$": "$.trigger.interactiveProcessId",
          "message": "<p>Hello,<br><br>Immediate termination cannot be processed as this is a non person account.</p>\n<p>Thank You,<br>Support</p>",
          "ownerId.$": "$.trigger.launchedBy.id",
          "title": "Emergency Termination Failed"
        },
        "displayName": "Display message for Non Person Identity",
        "nextStep": "End Step - Success",
        "type": "action",
        "versionNumber": 1
      },
      "Send Email": {
        "actionId": "sp:send-email",
        "attributes": {
          "body": "<p>Hello Team,<br><br>This is to inform you that {{$.getIdentity1.attributes.displayName}}, has been terminated effective today.</p>\n<p>Thank You,<br>Support</p>",
          "context": {},
          "recipientEmailList": [
            "ujjwaljain@test.com"
          ],
          "subject": "[Action Required]: Emergency Termination"
        },
        "displayName": "Send success email ",
        "nextStep": "End Step - Success",
        "type": "action",
        "versionNumber": 2
      },
      "Send Email 1": {
        "actionId": "sp:send-email",
        "attributes": {
          "body": "<p>Hello Team,<br><br>This is to inform you that immediate termination failed for user: {{$.getIdentity1.attributes.displayName}}.</p>\n<p>Thank You,<br>Support</p>",
          "context": {},
          "recipientEmailList": [
            "ujjwaljain@test.com"
          ],
          "subject": "[Action Required]: Emergency Termination"
        },
        "displayName": "Send failure email",
        "nextStep": "End Step - Success",
        "type": "action",
        "versionNumber": 2
      }
    }
  },
  "enabled": false,
  "executionCount": 0,
  "failureCount": 0,
  "trigger": {
    "type": "EVENT",
    "attributes": {
      "filter.$": "$[?(@.workflowId == '0******************************c')]",
      "id": "idn:interactive-process-launched"
    }
  }
}
